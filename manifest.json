{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "2.0a1",
  "default_locale": "en-US",
  "author": "Jürgen Ernst, Dipl.-Ing.(FH)/Toshi_",
  "homepage_url": "https://addons.thunderbird.net/ja/thunderbird/addon/display-mail-user-agent-t/",
  "applications": {
    "gecko": {
      "id": "DisplayMailUserAgent-T-me@Toshi_",
      "strict_min_version": "68.3"
    }
  },
  "permissions": [
    "messagesRead"
  ],
  "background": {
    "scripts": ["scripts/dispmua.js", "scripts/dispmua-common.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"]
    }
  ],
  "web_accessible_resources": [
    "images/*.png",
    "content/dispmua-database.json",
    "content/48x48/*.png"
  ],
  "message_display_action": {
    "default_title": "dispMUA"
  },
  "icons": {
    "32": "images/logo.png",
    "64": "images/logo64.png"
  }
}