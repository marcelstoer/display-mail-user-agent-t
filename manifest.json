{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "2.9",
  "default_locale": "en-US",
  "author": "Jürgen Ernst, Dipl.-Ing.(FH)/Toshi_",
  "homepage_url": "https://addons.thunderbird.net/thunderbird/addon/display-mail-user-agent-t/",
  "applications": {
    "gecko": {
      "id": "DisplayMailUserAgent-T@Toshi_",
      "strict_min_version": "79.0a1"
    }
  },
  "permissions": [
    "messagesRead", "messagesModify", "storage", "accountsRead", "downloads"
  ],
  "background": {
    "scripts": ["scripts/dispmua.js", "scripts/dispmua-common.js"]
  },
  "options_ui" : {
    "page": "content/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    "images/*.png",
    "images/*.gif",
    "scripts/content-scripts.js",
    "content/dispmua-database.json",
    "content/48x48/*.png"
  ],
  "message_display_action": {
  },
  "icons": {
    "32": "images/logo.png",
    "64": "images/logo64.png"
  }
}